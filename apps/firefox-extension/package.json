{
  "name": "@echo/firefox-extension",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/build.mjs --watch",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "package": "node scripts/build.mjs --release && web-ext build --source-dir build --artifacts-dir artifacts --overwrite-dest --filename echo-local-assistant-0.1.0.xpi"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.4",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "web-ext": "^8.4.0"
  }
}
