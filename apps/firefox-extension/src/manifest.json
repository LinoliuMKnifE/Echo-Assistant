{
  "manifest_version": 3,
  "name": "Echo Local Assistant",
  "version": "0.1.0",
  "description": "Share explicitly selected browser context with the local Echo desktop assistant.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:43117/*"],
  "background": { "scripts": ["dist/background.js"] },
  "action": {
    "default_title": "Echo quick actions",
    "default_popup": "popup.html"
  },
  "sidebar_action": {
    "default_title": "Echo chat",
    "default_panel": "sidebar.html",
    "open_at_install": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "luma-local-assistant@luma.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["browsingActivity", "websiteContent", "personalCommunications"]
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src http://127.0.0.1:43117; img-src 'self' data:; object-src 'none'; base-uri 'none'"
  }
}
